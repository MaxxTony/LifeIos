{
  "expo": {
    "name": "LifeOS",
    "slug": "LifeOS",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lifeos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lifeos.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "LifeOS needs access to your photos to let you share them with the AI assistant.",
        "NSCameraUsageDescription": "LifeOS needs access to your camera to let you take photos for the AI assistant.",
        "NSMicrophoneUsageDescription": "LifeOS needs access to your microphone for voice commands and audio analysis."
      }
    },
    "android": {
      "package": "com.lifeos.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0B0B0F"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0b0b0f",
          "dark": {
            "backgroundColor": "#0b0b0f"
          }
        }
      ],
      "./plugins/withAsyncStorageRepo",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.191144362794-1b4frlkh9l96dpcc86gf6ssj491g4tjm"
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}