{
  "expo": {
    "name": "LifeOS",
    "slug": "LifeOS",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lifeos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lifeos.prime",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "LifeOS needs access to your photos to let you share them with the AI assistant.",
        "NSCameraUsageDescription": "LifeOS needs access to your camera to let you take photos for the AI assistant.",
        "NSMicrophoneUsageDescription": "LifeOS needs access to your microphone for voice commands and audio analysis.",
        "UIBackgroundModes": [
          "fetch"
        ]
      }
    },
    "android": {
      "package": "com.lifeos.prime",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0B0B0F"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0b0b0f",
          "dark": {
            "backgroundColor": "#0b0b0f"
          }
        }
      ],
      "./plugins/withAsyncStorageRepo",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.191144362794-jlfstgpenl1tkn2ofdunsd1kb64m2nfs"
        }
      ],
      "expo-notifications",
      [
        "@sentry/react-native/expo",
        {
          "organization": "lifeos",
          "project": "react-native"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a21c2c05-ab8d-477f-97b2-5ff66062bc33"
      }
    }
  }
}
