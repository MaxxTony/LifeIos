rules_version = '2';

// LifeOS Firestore Security Rules
// ================================
// Deploy with:  firebase deploy --only firestore:rules
// Test with the emulator before shipping:  firebase emulators:exec --only firestore "npm test"
//
// Model: every user owns /users/{userId} and everything beneath it.
// No cross-user reads, no unauthenticated reads, no root collection writes.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers -------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Reject any write that tries to mutate the uid field away from the
    // authenticated user. Defence-in-depth against impersonation attempts.
    function ownsPayload(userId) {
      return !('userId' in request.resource.data)
        || request.resource.data.userId == userId;
    }

    // ---- User document + all sub-collections ---------------------------
    match /users/{userId} {
      allow read:   if isOwner(userId);
      allow create: if isOwner(userId) && ownsPayload(userId);
      allow update: if isOwner(userId) && ownsPayload(userId);
      allow delete: if isOwner(userId);

      // F-4: Field-level validation for sub-collections
      
      match /tasks/{taskId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId)
          && request.resource.data.keys().hasOnly(['id', 'text', 'priority', 'date', 'completed', 'status', 'createdAt', 'startTime', 'endTime', 'dueTime', 'repeat', 'subtasks', 'systemComment', 'serverCreatedAt', 'xpAwarded'])
          && request.resource.data.text is string && request.resource.data.text.size() < 1000;
      }

      match /habits/{habitId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId)
          && request.resource.data.keys().hasOnly(['id', 'title', 'frequency', 'targetDays', 'reminderTime', 'completedDays', 'bestStreak', 'currentStreak', 'xpAwardedDays', 'createdAt', 'pausedUntil', 'serverCreatedAt', 'lastUpdatedAt'])
          && request.resource.data.title is string && request.resource.data.title.size() < 200
          && request.resource.data.completedDays is list && request.resource.data.completedDays.size() <= 600;
      }

      match /moodHistory/{date} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId)
          && (request.resource.data.keys().hasAll(['mood']) || request.method == 'delete')
          && (!('mood' in request.resource.data) || request.resource.data.mood in ['great', 'good', 'neutral', 'bad', 'awful']);
      }

      match /focusHistory/{date} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId)
          && request.resource.data.keys().hasOnly(['totalSeconds', 'serverUpdatedAt']);
      }

      match /conversations/{convId} {
        allow read, write: if isOwner(userId);
        
        match /messages/{msgId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId) 
            && request.resource.data.content is string 
            && request.resource.data.content.size() < 5000;
        }
      }

      // Catch-all for other sub-collections
      match /{subCollection}/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ---- Default deny --------------------------------------------------
    // Anything not explicitly matched above is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
