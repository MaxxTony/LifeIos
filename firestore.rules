rules_version = '2';

// LifeOS Firestore Security Rules
// ================================
// Deploy with:  firebase deploy --only firestore:rules
// Test with the emulator before shipping:  firebase emulators:exec --only firestore "npm test"
//
// Model: every user owns /users/{userId} and everything beneath it.
// No cross-user reads, no unauthenticated reads, no root collection writes.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers -------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Reject any write that tries to mutate the uid field away from the
    // authenticated user. Defence-in-depth against impersonation attempts.
    function ownsPayload(userId) {
      return !('userId' in request.resource.data)
        || request.resource.data.userId == userId;
    }

    // ---- User document + all sub-collections ---------------------------
    match /users/{userId} {
      allow read:   if isOwner(userId);
      allow create, update: if isOwner(userId) && ownsPayload(userId)
        // AUDIT FIX (BUG-001, BUG-002): Removed 'isPro', 'subscriptionExpiryDate',
        // 'dailyAIMessageCount', and 'lastAIMessageCountReset' from this allowlist.
        // These fields are now ONLY writable by Cloud Functions via the admin SDK.
        // Leaving them here allowed any authenticated user to self-grant Pro access
        // or reset their daily AI limit via the Firestore REST API.
        && request.resource.data.keys().hasOnly(['userName', 'email', 'createdAt', 'onboardingData', 'focusGoalHours', 'mood', 'moodTheme', 'lastResetDate', 'bio', 'location', 'occupation', 'avatarUrl', 'phoneNumber', 'birthday', 'pronouns', 'skills', 'socialLinks', 'themePreference', 'accentColor', 'notificationSettings', 'lastActiveTimestamp', 'completedQuests', 'hasCompletedOnboarding', 'hasSeenWalkthrough', 'sessionToken', 'lastMoodLog', 'recentXP', 'streakMilestones', 'proactivePrompt', '_lastRetryAt', 'syncStatus', 'pendingActions', '_subscriptionGen', 'userId', 'homeTimezone', 'struggles', '_migrationComplete', 'lastLoginBonusDate', 'streakFreezes', 'preferredNudgeTime', 'hasSeenDailyHighlight', 'lastComebackScheduledDate', 'aiInsight']);
      allow delete: if isOwner(userId);

      match /tasks/{taskId} {
        allow read, write: if isOwner(userId);
      }
 
      match /habits/{habitId} {
        allow read, write: if isOwner(userId);
      }
 
      match /moodHistory/{date} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId)
          && (request.method == 'delete' || (
              request.resource.data.mood is number 
              && request.resource.data.mood >= 1 
              && request.resource.data.mood <= 5
              && request.resource.data.keys().hasOnly(['mood', 'timestamp', 'reason', 'activities', 'emotions', 'note', 'createdAt', 'serverCreatedAt', 'lastUpdatedAt'])
          ));
      }
 
      match /focusHistory/{date} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId)
          && (request.method == 'delete' || request.resource.data.keys().hasOnly(['totalSeconds', 'serverUpdatedAt']));
      }
 
      match /conversations/{convId} {
        allow read, write: if isOwner(userId);
        
        match /messages/{msgId} {
          allow read, write: if isOwner(userId);
        }
      }
 
      // AUDIT FIX (BUG-NEW-001): stats/global is now READ-ONLY for clients.
      // All XP/level/streak writes go through xpBuffer → Cloud Function pipeline
      // or via admin SDK in Cloud Functions. Allowing client writes let any user
      // set {totalXP: 999999, level: 99} and destroy the leaderboard.
      match /stats/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /lifeScoreHistory/{date} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId)
          && (request.method == 'delete' || request.resource.data.keys().hasOnly(['score']));
      }
 
      match /dailyQuests/{questId} {
        allow read, write: if isOwner(userId);
      }

      match /memories/{memoryId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.content is string
          && request.resource.data.content.size() < 2000
          && request.resource.data.keys().hasOnly(['id', 'content', 'timestamp', 'type', 'tags', 'lastUpdatedAt', 'serverUpdatedAt']);
      }

      match /weeklyRecaps/{recapId} {
        allow read, write: if isOwner(userId);
      }
    } // end of match /users/{userId}

    match /publicProfiles/{profileId} {
      // Allows friends/users to read the public profile data
      allow read: if isSignedIn();
      allow write: if isOwner(profileId)
        // O9 FIX: Added 'userNameLower' to allowlist (used for case-insensitive search).
        && (request.method == 'delete' || request.resource.data.keys().hasOnly(['level', 'weeklyXP', 'globalStreak', 'lastActive', 'userName', 'userNameLower', 'avatarUrl', 'lastUpdatedAt']));
    }

    match /friendRequests/{requestId} {
      allow create: if isSignedIn() 
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId != request.auth.uid 
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly(['id', 'fromUserId', 'toUserId', 'status', 'createdAt']);
      
      allow read, delete: if isSignedIn()
        && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);

      allow update: if isSignedIn()
        && (resource.data.toUserId == request.auth.uid || resource.data.fromUserId == request.auth.uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in ['accepted', 'declined', 'pending'];
    }

    // AUDIT FIX (BUG-003): Added amount bounds (> 0, <= 100) to prevent
    // XP injection. Without this cap, any user could create {amount: 999999}
    // and inflate their XP/leaderboard position.
    match /xpBuffer/{txId} {
      allow create: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.amount <= 100
        && request.resource.data.keys().hasOnly(['userId', 'amount', 'timestamp']);
    }

    match /feedback/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly(['text', 'rating', 'userId', 'createdAt', 'serverCreatedAt'])
        && request.resource.data.text is string
        && request.resource.data.text.size() < 2000
        && (request.resource.data.createdAt == request.time || request.resource.data.createdAt is string);
    }

    // ---- Default deny --------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
  
