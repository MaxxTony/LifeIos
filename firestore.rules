rules_version = '2';

// LifeOS Firestore Security Rules
// ================================
// Deploy with:  firebase deploy --only firestore:rules
// Test with the emulator before shipping:  firebase emulators:exec --only firestore "npm test"
//
// Model: every user owns /users/{userId} and everything beneath it.
// No cross-user reads, no unauthenticated reads, no root collection writes.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers -------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Reject any write that tries to mutate the uid field away from the
    // authenticated user. Defence-in-depth against impersonation attempts.
    function ownsPayload(userId) {
      return !('userId' in request.resource.data)
        || request.resource.data.userId == userId;
    }

    // ---- User document + all sub-collections ---------------------------
    match /users/{userId} {
      allow read:   if isOwner(userId);
      allow create, update: if isOwner(userId) && ownsPayload(userId)
        // O12 FIX: Removed 'totalXP' and 'level' from this allowlist.
        // XP must only be written to users/{userId}/stats/global (the sub-collection),
        // which is protected by a separate rule. Keeping them here allowed a user
        // to self-edit their XP via the Firestore REST API with their own auth token.
        && request.resource.data.keys().hasOnly(['userName', 'email', 'createdAt', 'onboardingData', 'focusGoalHours', 'mood', 'moodTheme', 'lastResetDate', 'bio', 'location', 'occupation', 'avatarUrl', 'phoneNumber', 'birthday', 'pronouns', 'skills', 'socialLinks', 'themePreference', 'accentColor', 'notificationSettings', 'lastActiveTimestamp', 'completedQuests', 'hasCompletedOnboarding', 'hasSeenWalkthrough', 'sessionToken', 'lastMoodLog', 'recentXP', 'streakMilestone', 'proactivePrompt', '_lastRetryAt', 'syncStatus', 'pendingActions', '_subscriptionGen', 'userId', 'homeTimezone', 'struggles', '_migrationComplete', 'lastLoginBonusDate', 'streakFreezes']);
      allow delete: if isOwner(userId);

      match /tasks/{taskId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.keys().hasOnly(['id', 'text', 'priority', 'date', 'completed', 'status', 'createdAt', 'dueTime', 'startTime', 'endTime', 'systemComment', 'repeat', 'subtasks', 'xpAwarded', 'serverCreatedAt', 'lastUpdatedAt'])
          && request.resource.data.text is string;
        allow delete: if isOwner(userId);
      }
 
      match /habits/{habitId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.keys().hasOnly(['id', 'title', 'icon', 'category', 'color', 'frequency', 'targetDays', 'monthlyTarget', 'monthlyDay', 'reminderTime', 'goalDays', 'completedDays', 'bestStreak', 'currentStreak', 'xpAwardedDays', 'createdAt', 'pausedUntil', 'serverCreatedAt', 'lastUpdatedAt'])
          && request.resource.data.title is string;
        allow delete: if isOwner(userId);
      }
 
      match /moodHistory/{date} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId)
          && (request.method == 'delete' || (
              request.resource.data.mood is number 
              && request.resource.data.mood >= 1 
              && request.resource.data.mood <= 5
              && request.resource.data.keys().hasOnly(['mood', 'timestamp', 'reason', 'activities', 'emotions', 'note', 'createdAt', 'serverCreatedAt', 'lastUpdatedAt'])
          ));
      }
 
      match /focusHistory/{date} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId)
          && (request.method == 'delete' || request.resource.data.keys().hasOnly(['totalSeconds', 'serverUpdatedAt']));
      }
 
      match /conversations/{convId} {
        allow read, write: if isOwner(userId);
        
        match /messages/{msgId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId) 
            && request.resource.data.content is string;
          allow delete: if isOwner(userId);
        }
      }
 
      match /stats/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId)
          && (request.method == 'delete' || request.resource.data.keys().hasOnly(['totalXP', 'level', 'weeklyXP', 'globalStreak', 'lastActiveDate', 'lastWeekResetDate', 'lastUpdatedAt']));
      }

      match /lifeScoreHistory/{date} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId)
          && (request.method == 'delete' || request.resource.data.keys().hasOnly(['score']));
      }
 
      match /dailyQuests/{questId} {
        allow read: if isOwner(userId);
        allow write, create: if isOwner(userId)
          && (request.method == 'delete' || request.resource.data.keys().hasOnly(['id', 'title', 'targetCount', 'currentCount', 'rewardXP', 'icon', 'type', 'completed', 'date']));
      }
    } // end of match /users/{userId}

    match /publicProfiles/{profileId} {
      // Allows friends/users to read the public profile data
      allow read: if isSignedIn();
      allow write: if isOwner(profileId)
        // O9 FIX: Added 'userNameLower' to allowlist (used for case-insensitive search).
        && (request.method == 'delete' || request.resource.data.keys().hasOnly(['level', 'weeklyXP', 'globalStreak', 'lastActive', 'userName', 'userNameLower', 'avatarUrl', 'lastUpdatedAt']));
    }

    match /friendRequests/{requestId} {
      allow create: if isSignedIn() 
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.keys().hasOnly(['id', 'fromUserId', 'toUserId', 'status', 'createdAt']);
      
      allow read, update, delete: if isSignedIn()
        && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
    }

    match /feedback/{id} {
      allow create: if isSignedIn();
    }

    // ---- Default deny --------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
  
