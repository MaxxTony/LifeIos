{
  "rules": {
    "focusRoom": {
      "$uid": {
        ".read": "auth != null && (data.child('isPublic').val() === true || auth.uid === $uid)",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['userName', 'lastActive', 'status'])"
      }
    }
  }
}
